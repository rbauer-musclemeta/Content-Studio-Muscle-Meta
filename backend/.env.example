# Muscle-Meta Matrix Backend Configuration
# Copy this file to .env and fill in your values

# =============================================================================
# MongoDB (Product App: courses, newsletters, users, payments)
# =============================================================================
MONGO_URL=mongodb://localhost:27017
DB_NAME=muscle_meta_matrix

# =============================================================================
# PostgreSQL (CRF Clinical Engine: assessments, biomarkers, clinical data)
# =============================================================================
# Required for /api/crf/* endpoints and assessment persistence
CRF_DATABASE_URL=postgresql://user:password@localhost:5432/crf_clinical

# =============================================================================
# Stripe (Payment Processing)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# AI/LLM Services (optional, for course generation)
# =============================================================================
OPENAI_API_KEY=sk-...
GOOGLE_AI_API_KEY=...

# =============================================================================
# Application Settings
# =============================================================================
DEBUG=false
LOG_LEVEL=INFO

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
