# MongoDB Configuration
# Get this from MongoDB Atlas: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
MONGO_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority

# Database Name
DB_NAME=muscle_meta_db

# Stripe API Key
# Get from: https://dashboard.stripe.com/test/apikeys
# Use TEST key for development: sk_test_xxxxx
# Use LIVE key for production: sk_live_xxxxx
STRIPE_API_KEY=sk_test_YOUR_STRIPE_SECRET_KEY

# JWT Secret Key
# Generate a secure random string at: https://randomkeygen.com/
# Or use: openssl rand -hex 32
JWT_SECRET_KEY=your-super-secret-jwt-key-change-this-in-production

# Python Version (optional, for Render)
PYTHON_VERSION=3.11.0
